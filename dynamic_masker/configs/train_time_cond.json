{
  "experiment": "Default",
  "data": {
    "path": "/data/scratch/pellerito/datasets/DSEC",
    "mode": "time",
    "window": 0.01,
    "representation": "voxel",
    "voxel_bins": 2,
    "max_num_grad_events": 10000,

    "scales_loss": 1,
    "passes_loss": 4,

    "dt_ms": [0, 10, 50]

  },
"model": {
      "final_w_scale": 0.01,
      "num_encoders": 4,
      "num_residual_blocks": 2
    },
  "loss": {
    "warping": "Iterative",
    "iterative_mode": "two",
    "round_ts": false,
    "flow_scaling": 32,
    "flow_spat_smooth_weight": null,
    "flow_temp_smooth_weight": null,
    "clip_grad": 100.0
  },
  "optimizer": {
    "name": "AdamW",
    "lr": 0.00001
  },
  "loader": {
    "checkpoints_path": "checkpoints",
    "n_epochs": 5000,
    "batch_size": 1,
    "resolution": [480, 640],
    "augment": ["Horizontal", "Vertical", "Polarity"],
    "augment_prob": [0.5, 0.5, 0.5],
    "max_num_grad_events": 10000,
    "gpu": 0,
    "seed": null,
    "n_workers": 1
  },
  "vis": {
    "verbose": true,
    "log_wandb": true,
    "enabled": false,
    "store": false,
    "px": 400,
    "plot": false
  }
  }
  