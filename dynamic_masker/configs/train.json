{
  "experiment": "Default",
  "data": {
    "path": "/data/scratch/pellerito/datasets/DSEC",
    "mode": "time",

    "representation": "voxel",
    "voxel_bins": 2,

    "window": 0.01,
    "sequence_len": 10,
    "scales_loss": 1,
    "cache": false
  },
  "model": {
        "final_w_scale": 1.0,
        "num_encoders": 5
      },
  "loss": {
    "name": "BCEDiceLoss",
    "clip_grad": 5.0,
    "alpha": 0.9,
    "gamma": 1.0,
    "bce_weight": 1,
    "dice_weight": 0,
    "class_weights": 5.0
  },
  "optimizer": {
    "name": "AdamW",
    "lr": 0.0001
  },
  "loader": {
    "checkpoints_path": "checkpoints",
    "n_epochs": 5000,
    "batch_size": 1,
    "resolution": [128, 128],
    "augment": ["Horizontal", "Vertical", "Polarity"],
    "augment_prob": [0.5, 0.5, 0.5],
    "max_num_grad_events": 10000,
    "gpu": 0,
    "seed": null,
    "n_workers": 6
  },
  "vis": {
    "verbose": true,
    "log_wandb": true,
    "enabled": false,
    "store": false,
    "px": 400
  }
}