{
  "experiment": "Default",
  "data": {
    "path": "/data/storage/pellerito/datasets/DSEC",
    "mode": "time",
    "window": 0.01,
    "sequence_len": 5,
    "representation": "voxel",
    "voxel_bins": 15,
    "dt_ms": [0, 100],

    "scales_loss": 1,
    "passes_loss": 5
  },
  "model": {
        "final_w_scale": 1.0,
        "num_encoders": 5,
        "num_residual_blocks": 4
      }, 
  "custom":{
    "final_w_scale_flow": 0.01,
    "current_flow_sup": false
  } ,
  "loss": {
        "name": "HydraLoss",
        "clip_grad": 5.0,
        "bce_weight": 1,
        "dice_weight": 0,
        "class_weights": 5.0,
        "alpha": 0.9,
        "gamma": 1.0,
        "lambda_future_mask": 1.0,
        "lambda_flow": 0.1,
        "lambda_flow_smooth": 0.005,

        "warping": "Iterative",
        "iterative_mode": "two",
        "round_ts": false,
        "flow_spat_smooth_weight": null,
        "flow_temp_smooth_weight": null,

        "w_sup":2.0,
        "w_unsup": 1.0
  },
  "optimizer": {
    "name": "AdamW",
    "lr": 0.0001
  },
  "loader": {
    "checkpoints_path": "checkpoints",
    "n_epochs": 5000,

    "batch_size": 1,
    "max_num_grad_events": 10000,
    "n_workers": 2,

    "resolution": [128, 128],
    "augment": ["Horizontal", "Vertical", "Polarity"],
    "augment_prob": [0.5, 0.5, 0.5],
    "seed": null,
    "gpu": 0,
    "optical_flow_dt_ms": 100,
    "event_dt_ms": 100,

    "shuffle": true,
    "prefetch_factor": 1
  },
  "vis": {
    "verbose": true,
    "log_wandb": true,
    "plot": false,
    "enabled": false,
    "store": false,
    "px": 400
  }
}
  