{
  "experiment": "Default",
  "data": {
    "path": "/data/scratch/pellerito/datasets/DSEC",
    "mode": "time",
    "window": 0.01,
    "voxel_bins": 15,
    "representation": "stack"
  },
  "loss": {
    "bce_weight": 1,
    "dice_weight": 0,
    "class_weights": 5.0,
    "alpha": 0.9,
    "gamma": 1.0,
    "lambda_future_mask": 1.0,
    "lambda_flow": 0.1,
    "lambda_flow_smooth": 0.05
  },
  "model": {
    "final_w_scale": 1.0,
    "num_encoders": 5,
    "num_residual_blocks": 2
    },
  "custom":{
    "final_w_scale_flow": 0.01,
    "current_flow_sup": false
    } ,
  "loader": {
      "gpu": 0,
      "resolution": [480, 640],
      "optical_flow_dt_ms": 100,
      "event_dt_ms": 50
    },
  "vis": {
      "plot": true,
      "verbose": true
    }
  }
  