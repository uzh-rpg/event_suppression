{
  "experiment": "Default",
  "data": {
    "path": "/data/scratch/pellerito/datasets/EED",
    "mode": "time",
    "window": 0.05,
    "voxel_bins": 2,
    "representation": "voxel"
  },
  "loss": {
    "bce_weight": 1,
    "dice_weight": 0,
    "class_weights": 5.0,
    "alpha": 0.9,
    "gamma": 1.0,
    "lambda_future_mask": 1.0,
    "lambda_flow": 0.1,
    "lambda_flow_smooth": 0.05
  },
  "vis": {
    "plot": true,
    "verbose": true
  },
  "eval": {
    "mask_threshold": 0.4
  },
  "model": {
    "final_w_scale": 0.01,
    "num_encoders": 4,
    "num_residual_blocks": 2
  },
  "custom": {
    "final_w_scale_flow": 0.01,
    "current_flow_sup": false
  },
  "loader": {
    "gpu": 0,
    "resolution": [
      180,
      190
    ],
    "event_dt_ms": 10,
    "optical_flow_dt_ms": 100
  }
}
